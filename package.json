{
  "name": "spring-toever-ops",
  "version": "1.0.0",
  "description": "투에버-이지어드민 주문·송장 자동화 운영 프로그램",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,green \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build:electron": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3 --module-dir .",
    "build": "npm run build:electron && npm run build:renderer && electron-builder --config electron-builder.yml",
    "build:dir": "npm run build:electron && npm run build:renderer && electron-builder --dir --config electron-builder.yml",
    "preview": "vite preview",
    "install:playwright": "npx playwright install chromium --with-deps"
  },
  "keywords": [],
  "author": "Spring Toever Ops",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/iconv-lite": "^0.0.1",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "date-fns": "^4.0.0",
    "iconv-lite": "^0.6.3",
    "node-cron": "^3.0.0",
    "playwright": "^1.50.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  }
}
